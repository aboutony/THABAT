# THABAT — Production Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# DELIVERY TEAM INSTRUCTIONS:
#   1. Copy this file to .env.production in your hosting environment
#   2. Replace every REPLACE_WITH_* value with real credentials
#   3. NEVER commit the filled-in .env.production file to git
#   4. Store secrets in your hosting provider's secret manager (Vercel, Railway, etc.)
#   5. Run `npm run db:migrate` after provisioning the Turso DB
#
# See docs/environment-strategy.md for full setup guide.
# See docs/delivery-team-handoff.md for Turso provisioning steps.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App Mode ────────────────────────────────────────────────────────────────
# IMPORTANT: Must be 'false' in production — enables real DB data paths
NEXT_PUBLIC_DEMO_MODE=false

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ─── Admin ────────────────────────────────────────────────────────────────────
THABAT_ADMIN_KEY=REPLACE_WITH_ADMIN_KEY

# ─── Database (Turso / libSQL) ────────────────────────────────────────────────
# Provision at: https://turso.tech (free tier: 500MB storage, 1B row reads/month)
# CLI: turso db create thabat-prod && turso db show thabat-prod
TURSO_DATABASE_URL=libsql://REPLACE_WITH_DB_NAME-REPLACE_WITH_ORG.turso.io
# CLI: turso db tokens create thabat-prod
TURSO_AUTH_TOKEN=REPLACE_WITH_TURSO_AUTH_TOKEN

# ─── Observability ────────────────────────────────────────────────────────────
# Sentry free tier: https://sentry.io — create a Next.js project, copy DSN here
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN

# ─── ERP Credential Encryption ───────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters. Rotate this key requires re-encrypting all stored ERP creds.
ERP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHAR_KEY
