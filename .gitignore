# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# database (local dev)
*.db
*.db-shm
*.db-wal

# env files — secrets must NEVER be committed
.env
.env.local
.env.demo
.env.production
.env.*.local
# these ARE committed (templates with placeholders — no real secrets)
!.env.example
!.env.production.template

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
