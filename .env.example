# THABAT — Environment Variable Reference
# This file is safe to commit. It contains no real secrets.
# Copy this file to .env (local dev) or .env.production (delivery team) and fill in real values.
# See docs/environment-strategy.md for full setup instructions.

# ─── App Mode ────────────────────────────────────────────────────────────────
# Controls whether hardcoded demo data or real DB data is used throughout the app.
# Set to 'true' for demo/staging environments, 'false' for production.
NEXT_PUBLIC_DEMO_MODE=true

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NEVER reuse the demo secret in production.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ─── Admin ────────────────────────────────────────────────────────────────────
# Used to authorize admin-only API routes (/api/admin/*).
# Generate a separate strong secret for this.
THABAT_ADMIN_KEY=REPLACE_WITH_ADMIN_KEY

# ─── Database (Turso / libSQL) ────────────────────────────────────────────────
# Turso database URL — format: libsql://<db-name>-<org>.turso.io
# Provision at: https://turso.tech (free tier available)
TURSO_DATABASE_URL=libsql://YOUR_DB_NAME-YOUR_ORG.aws-ap-south-1.turso.io

# Turso authentication token — generate with: turso db tokens create <db-name>
TURSO_AUTH_TOKEN=REPLACE_WITH_TURSO_AUTH_TOKEN

# ─── Observability (Phase 1.8) ────────────────────────────────────────────────
# Sentry DSN — get from https://sentry.io (free tier: 5,000 errors/month)
# Leave empty to disable Sentry (observability will fall back to structured logs only)
SENTRY_DSN=

# ─── ERP Encryption ──────────────────────────────────────────────────────────
# 32-byte key used for AES-256-GCM encryption of ERP credentials stored in DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes).
ERP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHAR_KEY
